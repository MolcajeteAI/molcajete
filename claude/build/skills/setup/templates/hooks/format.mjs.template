#!/usr/bin/env node

// format hook — run formatter in check/verify mode
// Generated by /m:setup — edit freely or replace with any language.
//
// Input (stdin):  { "files": ["src/foo.ts"], "services": ["server", "bdd"], "feature_id": "...", "usecase_id": "...", "scenario_id": "..." }
// Output (stdout): { "status": "pass"|"fail", "issues": ["src/foo.ts: not formatted"] }

import { execSync } from 'node:child_process';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';

// Resolve repo root for tool paths (venvs, node_modules live in main repo, not worktrees).
// NOTE: Do NOT process.chdir — cwd comes from the orchestrator (may be a worktree).
const __dirname = dirname(fileURLToPath(import.meta.url));
const repoRoot = resolve(__dirname, '..', '..');

const SCHEMA = {
  input: {
    files: { type: 'string[]', required: false },
    services: { type: 'string[]', required: false },
    feature_id: { type: 'string', required: false },
    usecase_id: { type: 'string', required: false },
    scenario_id: { type: 'string', required: false },
  },
  output: {
    status: 'pass|fail',
    issues: 'string[]',
  },
};

const input = JSON.parse(await readStdin());
validateInput(input, SCHEMA);

const requestedFiles = input.files || [];
const requestedServices = input.services || [];

// __FORMAT_CONFIG_PLACEHOLDER__
// Each entry: { service, glob, command, fallback }
// Commands must use check/dry-run mode (--check, --diff) — never --write.
// The command uses {files} as a placeholder for matched file paths.
const formatters = [
  // { service: 'server', glob: 'server/**/*.go', command: 'cd server && gofmt -l {files}', fallback: 'cd server && gofmt -l .' },
  // { service: 'bdd', glob: 'bdd/**/*.py', command: 'ruff format --check {files}', fallback: 'ruff format --check bdd/' },
];

/** Simple glob matcher for patterns like 'dir/**/*.ext' */
function matchGlob(file, pattern) {
  const parts = pattern.split('/**/');
  if (parts.length !== 2) return file === pattern;
  const dir = parts[0];
  const extPattern = parts[1]; // e.g., '*.go' or '*.{ts,tsx}'
  if (!file.startsWith(dir + '/') && !file.startsWith(dir)) return false;
  if (extPattern.startsWith('*.')) {
    const extPart = extPattern.slice(1); // e.g., '.go' or '.{ts,tsx}'
    if (extPart.includes('{')) {
      const exts = extPart.slice(2, -1).split(',').map((e) => '.' + e);
      return exts.some((ext) => file.endsWith(ext));
    }
    return file.endsWith(extPart);
  }
  return true;
}

const issues = [];

for (const fmt of formatters) {
  if (requestedServices.length > 0 && !requestedServices.includes(fmt.service)) continue;

  let cmd;
  if (requestedFiles.length > 0) {
    let matched = requestedFiles.filter((f) => matchGlob(f, fmt.glob));
    if (matched.length === 0) continue;
    // Strip service prefix when command uses cd {dir} (avoids double-prefix)
    const cdMatch = fmt.command.match(/^cd\s+(\S+)\s+&&/);
    if (cdMatch) {
      const prefix = cdMatch[1] + '/';
      matched = matched.map((f) => (f.startsWith(prefix) ? f.slice(prefix.length) : f));
    }
    cmd = fmt.command.replace('{files}', matched.join(' '));
  } else {
    cmd = fmt.fallback;
  }

  // Resolve local tool paths (.venv/bin/, node_modules/.bin/) to main repo
  const cdDir = cmd.match(/^cd\s+(\S+)\s+&&/);
  if (cdDir) {
    cmd = cmd.replace(/\.venv\/bin\//g, `${repoRoot}/${cdDir[1]}/.venv/bin/`);
  }

  try {
    execSync(cmd, {
      encoding: 'utf8',
      stdio: ['pipe', 'pipe', 'pipe'],
      timeout: 60000,
    });
  } catch (err) {
    const output = (err.stdout || '') + '\n' + (err.stderr || '');
    const lines = output
      .trim()
      .split('\n')
      .filter((l) => l.trim())
      .slice(0, 100);

    for (const line of lines) {
      issues.push(`[${fmt.service}] ${line}`);
    }
  }
}

process.stdout.write(
  JSON.stringify({
    status: issues.length === 0 ? 'pass' : 'fail',
    issues,
  }) + '\n',
);

function readStdin() {
  return new Promise((resolve) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (chunk) => (data += chunk));
    process.stdin.on('end', () => resolve(data || '{}'));
  });
}

function validateInput(input, schema) {
  const errors = [];
  for (const [key, def] of Object.entries(schema.input)) {
    const required = typeof def === 'object' && def.required;
    if (required && (input[key] === undefined || input[key] === null)) {
      errors.push(`Missing required field: ${key}`);
    }
  }
  if (errors.length > 0) {
    process.stdout.write(JSON.stringify({ status: 'failed', errors }) + '\n');
    process.exit(1);
  }
}
