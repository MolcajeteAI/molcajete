#!/usr/bin/env node

// logs hook — retrieve environment logs
// Generated by /m:setup — edit freely or replace with any language.
//
// Input (stdin):  { "service": "postgres", "lines": 100, "since": "5m" }
// Output (stdout): { "status": "ok"|"failed", "logs": "..." }

import { execSync } from 'node:child_process';
import { readFileSync } from 'node:fs';

const SCHEMA = {
  input: {
    service: { type: 'string', required: false },
    lines: { type: 'number', required: false },
    since: { type: 'string', required: false },
  },
  output: {
    status: 'ok|failed',
    logs: 'string',
  },
};

function loadEnv(filePath) {
  try {
    const content = readFileSync(filePath, 'utf8');
    for (const line of content.split('\n')) {
      const trimmed = line.trim();
      if (!trimmed || trimmed.startsWith('#')) continue;
      const eq = trimmed.indexOf('=');
      if (eq === -1) continue;
      const key = trimmed.slice(0, eq).trim();
      const val = trimmed.slice(eq + 1).trim().replace(/^["']|["']$/g, '');
      if (!process.env[key]) process.env[key] = val;
    }
  } catch { /* .env not found — ok */ }
}

loadEnv('.env');

const input = JSON.parse(await readStdin());
validateInput(input, SCHEMA);

// __LOGS_COMMAND__
// e.g., 'docker compose logs'
const logsCommand = '__LOGS_COMMAND__';

// __SERVICE_MAP_PLACEHOLDER__
// Maps domain/alias names to actual service names
const serviceMap = {
  // 'postgres': 'postgres',
  // 'redis': 'redis',
  // 'app': 'app',
};

const service = input.service || 'all';
const lines = input.lines || 100;
const since = input.since || '';

let cmd = logsCommand;

if (service !== 'all') {
  const mappedService = serviceMap[service] || service;
  cmd += ` ${mappedService}`;
}

cmd += ` --tail ${lines}`;

if (since) {
  cmd += ` --since ${since}`;
}

try {
  const output = execSync(cmd, {
    encoding: 'utf8',
    stdio: ['pipe', 'pipe', 'pipe'],
    timeout: 30000,
  });

  process.stdout.write(
    JSON.stringify({ status: 'ok', logs: output.slice(0, 50000) }) + '\n',
  );
} catch (err) {
  const stderr = (err.stderr || '').toString().trim();
  const stdout = (err.stdout || '').toString().trim();
  process.stdout.write(
    JSON.stringify({
      status: 'failed',
      logs: stdout || stderr.slice(0, 500) || `exit code ${err.status}`,
    }) + '\n',
  );
}

function readStdin() {
  return new Promise((resolve) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (chunk) => (data += chunk));
    process.stdin.on('end', () => resolve(data || '{}'));
  });
}

function validateInput(input, schema) {
  const errors = [];
  for (const [key, def] of Object.entries(schema.input)) {
    const required = typeof def === 'object' && def.required;
    if (required && (input[key] === undefined || input[key] === null)) {
      errors.push(`Missing required field: ${key}`);
    }
  }
  if (errors.length > 0) {
    process.stdout.write(JSON.stringify({ status: 'failed', errors }) + '\n');
    process.exit(1);
  }
}
