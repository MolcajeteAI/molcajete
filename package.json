{
  "name": "@molcajete/cli",
  "version": "3.0.1",
  "type": "module",
  "description": "Molcajete CLI, spec-driven development harness with Claude Code",
  "bin": {
    "molcajete": "./dist/molcajete.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src/",
    "lint": "biome lint src/"
  },
  "files": [
    "dist/",
    "claude/"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "~13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@8.15.6+sha256.01c01eeb990e379b31ef19c03e9d06a14afa5250b82e81303f88721c99ff2e6f"
}
