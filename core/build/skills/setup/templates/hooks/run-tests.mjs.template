#!/usr/bin/env node

// run-tests hook — run BDD tests with tag filtering
// Generated by /m:setup — edit freely or replace with any language.
//
// Input (stdin):  { "tags": ["@SC-001", "@SC-002"], "scope": "task"|"preflight"|"final", "feature_id": "...", "usecase_id": "...", "scenario_id": "..." }
// Output (stdout): { "status": "pass"|"fail"|"error", "failures": [], "summary": "" }

import { execSync } from 'node:child_process';

const SCHEMA = {
  input: {
    tags: { type: 'string[]', required: true },
    scope: { type: 'string', required: true },
    feature_id: { type: 'string', required: false },
    usecase_id: { type: 'string', required: false },
    scenario_id: { type: 'string', required: false },
  },
  output: {
    status: 'pass|fail|error',
    failures: 'string[]',
    summary: 'string',
  },
};

const input = JSON.parse(await readStdin());
validateInput(input, SCHEMA);

// __BDD_CONFIG_PLACEHOLDER__
const bddCommand = '__BDD_COMMAND__';
const tagsFlag = '__TAGS_FLAG__'; // e.g., '--tags' for cucumber/behave
const formatFlags = '__FORMAT_FLAGS__'; // e.g., '--format json --no-capture'
const tagJoin = __TAG_JOIN__; // e.g., ' or ' for behave/cucumber

let cmd = bddCommand;

const tags = input.tags || [];
if (tags.length > 0) {
  const tagExpr = tags.join(tagJoin);
  cmd += ` ${tagsFlag} "${tagExpr}"`;
}

if (formatFlags) {
  cmd += ` ${formatFlags}`;
}

try {
  const output = execSync(cmd, {
    encoding: 'utf8',
    stdio: ['pipe', 'pipe', 'pipe'],
    timeout: 300000, // 5 min
  });

  process.stdout.write(
    JSON.stringify({ status: 'pass', failures: [], summary: 'All tests passed' }) + '\n',
  );
} catch (err) {
  const stderr = err.stderr || '';
  const stdout = err.stdout || '';

  // Distinguish setup errors from test failures
  const setupPatterns = [
    /connection refused/i,
    /command not found/i,
    /no such file or directory/i,
    /module not found/i,
    /cannot find module/i,
    /not installed/i,
  ];

  const isSetupError = setupPatterns.some((p) => p.test(stderr) || p.test(stdout));

  if (isSetupError) {
    process.stdout.write(
      JSON.stringify({
        status: 'error',
        failures: [`Setup error: ${(stderr || stdout).trim().slice(0, 500)}`],
        summary: 'Test infrastructure is broken — cannot run tests',
      }) + '\n',
    );
  } else {
    // Parse test output for individual failures
    const combined = stdout + '\n' + stderr;
    const failureLines = combined
      .split('\n')
      .filter((l) => /fail|error|assert/i.test(l))
      .slice(0, 50);

    process.stdout.write(
      JSON.stringify({
        status: 'fail',
        failures: failureLines.length > 0 ? failureLines : [`Tests failed: exit code ${err.status}`],
        summary: `${failureLines.length} test failure(s)`,
      }) + '\n',
    );
  }
}

function readStdin() {
  return new Promise((resolve) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', (chunk) => (data += chunk));
    process.stdin.on('end', () => resolve(data || '{}'));
  });
}

function validateInput(input, schema) {
  const errors = [];
  for (const [key, def] of Object.entries(schema.input)) {
    const required = typeof def === 'object' && def.required;
    if (required && (input[key] === undefined || input[key] === null)) {
      errors.push(`Missing required field: ${key}`);
    }
  }
  if (errors.length > 0) {
    process.stdout.write(JSON.stringify({ status: 'failed', errors }) + '\n');
    process.exit(1);
  }
}
